# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
#
# Note: No Anthropic API key needed.
# Intelligence is Claude Code (the CLI). This package provides tools and state management only.

# PostgreSQL (local)
POSTGRES_URL=postgresql://ai_scientist:ai_scientist@localhost:5432/ai_scientist

# Semantic Scholar (optional — higher rate limit with key)
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex polite pool (use your email for better rate limits)
OPENALEX_EMAIL=your@email.com
